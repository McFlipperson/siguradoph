generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityType {
  SOLE_PROPRIETOR
  PARTNERSHIP
  CORPORATION
}

enum FilingMethod {
  EBIRFORMS
  EFPS
}

enum UserRole {
  CLINIC_OWNER
  SECRETARY
  CPA
}

enum Plan {
  FREE
  BASIC
  PRO
}

enum UpgradeStatus {
  PENDING
  CONFIRMED
  EXPIRED
}

// Sigurado's OWN security incident register (Sigurado = Personal Information
// Processor under RA 10173). Company-level — NOT tied to any one clinic. Backs
// the Sigurado-side 72h breach clock and the company's annual ASIR. Distinct
// from the per-clinic IncidentLog. Admin-only.
model PlatformIncident {
  id                  String    @id @default(cuid())
  incidentDate        DateTime
  discoveryDate       DateTime
  type                String
  severity            String    @default("LOW")
  description         String    @db.Text
  natureOfData        String?
  clinicsAffected     Int       @default(0)   // how many clinics impacted
  individualsAffected Int       @default(0)
  measuresTaken       String?   @db.Text
  reportedToNpc       Boolean   @default(false)
  npcReportDate       DateTime?
  reportedToSubjects  Boolean   @default(false)
  status              String    @default("OPEN")
  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([discoveryDate])
}

// Sigurado-staff (super-admin) action log — e.g. plan changes via /admin.
// Cross-clinic by nature; only readable through the admin-gated route.
model AdminAuditLog {
  id             String   @id @default(cuid())
  actorEmail     String
  action         String   // SET_PLAN
  targetClinicId String
  detail         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

enum PaymentMethod {
  CASH
  GCASH
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOID
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  WALK_IN
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  DENTAL_SUPPLIES
  MEDICAL_SUPPLIES
  RENT
  UTILITIES
  INTERNET_PHONE
  PROFESSIONAL_FEES
  LICENSES_PERMITS
  MAINTENANCE
  OTHER
}

model Clinic {
  id                       String       @id @default(cuid())
  slug                     String?      @unique
  logoUrl                  String?
  name                     String
  ownerName                String
  street                   String
  city                     String
  province                 String
  zip                      String
  phone                    String
  email                    String
  facebookPageUrl          String?
  messengerPageId          String?
  messengerToken           String?
  tin                      String
  rdoCode                  String
  corNumber                String
  entityType               EntityType
  vatRegistered            Boolean      @default(true)
  vatRegistrationDate      DateTime?
  orSeriesStart            String
  orSeriesCurrentNumber    Int          @default(1)
  filingMethod             FilingMethod
  enrollmentDate           DateTime
  onboardingComplete       Boolean      @default(false)
  hasEmployees             Boolean      @default(false)
  sssEmployerNumber        String?
  philhealthEmployerNumber String?
  pagibigEmployerNumber    String?
  plan                     Plan         @default(FREE)  // subscription tier — gates features + patient cap
  loyaltyCardEnabled       Boolean      @default(true)
  loyaltyCardPrice         Decimal      @default(500)
  loyaltyValidityMonths    Int          @default(24)
  accountantEmail          String?
  // RA 10173 — the CLINIC's own Data Protection Officer (the clinic is the PIC).
  // Distinct from Sigurado's company DPO (lib/dpo.ts). The clinic provides this to
  // the NPC for ITS registration and shows it on its patient privacy notice.
  dpoName                  String?
  dpoEmail                 String?
  dpoPhone                 String?
  npcRegistrationNumber    String?      // the clinic's own NPC registration number (proof of compliance)
  npcRegistrationDate      DateTime?
  prcLicenseNo             String?      // dentist's PRC license number — printed on dental certificates
  signatureUrl             String?      // dentist's saved signature image — printed on dental certificates
  gcashNumber              String?      // clinic owner's GCash mobile number — used to match incoming payments
  tosAcceptedAt            DateTime?    // timestamp when DPA/ToS was accepted during onboarding
  trialEndsAt              DateTime?    // set to createdAt + 30 days on first create
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  users             User[]
  patients          Patient[]
  visits            Visit[]
  invoices          Invoice[]
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  employees         Employee[]
  appointments      Appointment[]
  loyaltyCards      LoyaltyCard[]
  equipment         Equipment[]
  suppliers         Supplier[]
  serviceCatalog    ServiceCatalog[]
  cpaAssignments        CpaClinicAssignment[]
  loyaltyCardTemplates  LoyaltyCardTemplate[]
  scheduledReminders    ScheduledReminder[]
  unlinkedMessengers    UnlinkedMessenger[]
  quarterlyReportLogs        QuarterlyReportLog[]
  thirteenthMonthRecords     ThirteenthMonthRecord[]
  recallRules                RecallRule[]
  pendingMessengerLink       PendingMessengerLink?
  incidentLogs               IncidentLog[]
  pendingUpgrades            PendingUpgrade[]
}

// RA 10173 — Security incident & data-breach register.
// Backs the 72-hour NPC breach notification clock and the Annual Security
// Incident Report (ASIR, due March 31 for the prior calendar year).
model IncidentLog {
  id                  String    @id @default(cuid())
  clinicId            String
  clinic              Clinic    @relation(fields: [clinicId], references: [id])
  incidentDate        DateTime  // when the incident occurred
  discoveryDate       DateTime  // when the clinic became aware — starts the 72h clock
  type                String    // UNAUTHORIZED_ACCESS | LOSS | UNAUTHORIZED_DISCLOSURE | SYSTEM_BREACH | RANSOMWARE | OTHER
  severity            String    @default("LOW")  // LOW | MEDIUM | HIGH
  description         String    @db.Text
  natureOfData        String?   // categories of personal data involved
  individualsAffected Int       @default(0)
  measuresTaken       String?   @db.Text  // containment / remediation
  reportedToNpc       Boolean   @default(false)
  npcReportDate       DateTime?
  reportedToSubjects  Boolean   @default(false)
  status              String    @default("OPEN")  // OPEN | CONTAINED | RESOLVED
  createdBy           String    // userEmail who logged it
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([clinicId, discoveryDate])
}

model UnlinkedMessenger {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
  psid       String
  receivedAt DateTime @default(now())
  isLinked   Boolean  @default(false)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  createdAt DateTime @default(now())

  cpaAssignments CpaClinicAssignment[]
}

model CpaClinicAssignment {
  id         String   @id @default(cuid())
  cpaUserId  String
  clinicId   String
  cpa        User     @relation(fields: [cpaUserId], references: [id])
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
  assignedAt DateTime @default(now())
}

model Patient {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  firstName       String
  middleName      String?
  lastName        String
  dateOfBirth     DateTime
  address         String
  addressLine2    String?   // optional 2nd line — unit/building/barangay
  phone           String
  email           String?
  philsysId       String?  // Philippine Identification System (PhilSys) ID — optional
  medicalHistory  String?
  medications     String?
  allergies       String?
  messengerPsid                String?  // Facebook Page-Scoped ID for Messenger reminders
  reminderChannel              String   @default("NONE")  // MESSENGER | EMAIL | SMS | NONE
  bracesComplete               Boolean  @default(false)
  pendingLoyaltyCardPurchase   Boolean  @default(false)
  // RA 9994 Senior Citizen
  isSeniorCitizen   Boolean  @default(false)
  scIdNumber        String?
  // RA 10754 PWD
  isPwd             Boolean  @default(false)
  pwdIdNumber       String?
  pwdDisabilityType String?  // VISUAL | HEARING | SPEECH | PHYSICAL | INTELLECTUAL | PSYCHOSOCIAL | LEARNING | MENTAL
  enrolledAt                   DateTime
  createdAt                    DateTime @default(now())
  anonymizedAt                 DateTime?  // set when PII is scrubbed under RA 10173 erasure while BIR financial records are retained

  consentRecords     ConsentRecord[]
  visits             Visit[]
  appointments       Appointment[]
  loyaltyCards       LoyaltyCard[]
  scheduledReminders ScheduledReminder[]
}

model ConsentRecord {
  id                      String   @id @default(cuid())
  patientId               String
  patient                 Patient  @relation(fields: [patientId], references: [id])
  clinicId                String
  npcConsentGiven         Boolean
  truthfulnessDeclaration Boolean
  surgicalConsentGiven    Boolean
  isMinor                 Boolean  @default(false)
  guardianName            String?
  guardianRelationship    String?
  consentDate             DateTime @default(now())
  consentMethod           String   @default("digital")
  noticeVersion           String?  // version of the privacy notice the data subject actually agreed to (RA 10173 evidence of WHAT was consented)
}

model Visit {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  visitDate     DateTime @default(now())
  diagnosis     String
  toothNumber   String?
  treatment     String
  notes         String?
  grossAmount       Decimal
  netAmount         Decimal
  vatAmount         Decimal
  procedureAmounts       Json?    // [{name:string,amount:number}] per-procedure breakdown
  appliedLoyaltyCardId   String?  // card used for discounts (own or family — no FK, applied at confirm time)
  purchaseNewLoyaltyCard Boolean  @default(false)
  waiveCardFee           Boolean  @default(false)
  loyaltyBenefits        Json?    // LoyaltyBenefitApplication[] stored at visit-save time
  intervalWeeks          Int?     // braces only — weeks until next alignment
  status        String   @default("ACTIVE") // ACTIVE | VOID
  createdAt     DateTime @default(now())

  invoice Invoice?
}

model Invoice {
  id                 String        @id @default(cuid())
  clinicId           String
  clinic             Clinic        @relation(fields: [clinicId], references: [id])
  visitId            String?       @unique
  visit              Visit?        @relation(fields: [visitId], references: [id])
  orNumber           String
  sellerName         String
  sellerTin          String
  sellerAddress      String
  buyerName          String?
  buyerAddress       String?
  serviceDescription String
  grossAmount        Decimal
  netAmount          Decimal
  vatAmount          Decimal
  discountAmount        Decimal       @default(0)
  loyaltyCardId         String?
  scPwdDiscountType     String?       // 'SC' | 'PWD'
  scPwdIdNumber         String?
  scPwdDiscountAmount   Decimal       @default(0)
  paymentMethod         PaymentMethod
  status             InvoiceStatus @default(ISSUED)
  transactionDate    DateTime      @default(now())
  eisTransmitted     Boolean       @default(false)
  eisTransmittedAt   DateTime?
  eisResponse        String?
  notes              String?
  createdAt          DateTime      @default(now())
}

model LoyaltyCard {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  cardNumber      String   @unique
  purchaseDate    DateTime @default(now())
  expiryDate      DateTime
  isActive        Boolean  @default(true)
  cleaningUses50  Int      @default(2)
  cleaningUses25  Int      @default(2)
  fillingUses50   Int      @default(2)
  fillingUses25   Int      @default(2)
  rctUses         Int      @default(2)
  dentureUses     Int      @default(2)
  bracesUses      Int      @default(2)
  wisdomToothUses Int      @default(2)
  extractionUses  Int      @default(8)

  usageHistory LoyaltyCardUsage[]
}

model LoyaltyCardUsage {
  id             String      @id @default(cuid())
  loyaltyCardId  String
  loyaltyCard    LoyaltyCard @relation(fields: [loyaltyCardId], references: [id])
  serviceType    String
  discountPct    Decimal
  discountAmount Decimal
  invoiceId      String
  usedAt         DateTime    @default(now())
}

model Appointment {
  id           String            @id @default(cuid())
  clinicId     String
  clinic       Clinic            @relation(fields: [clinicId], references: [id])
  patientId    String
  patient      Patient           @relation(fields: [patientId], references: [id])
  scheduledAt  DateTime
  type         String
  status       AppointmentStatus @default(SCHEDULED)
  notes        String?
  createdAt    DateTime          @default(now())
}

model Expense {
  id                 String          @id @default(cuid())
  clinicId           String
  clinic             Clinic          @relation(fields: [clinicId], references: [id])
  supplierId         String?
  supplier           Supplier?       @relation(fields: [supplierId], references: [id])
  date               DateTime
  description        String
  grossAmount        Decimal
  inputVatAmount     Decimal         @default(0)
  netAmount          Decimal
  category           ExpenseCategory
  receiptNumber      String?
  paymentMethod      String          @default("CASH")
  notes              String?
  isRecurring        Boolean         @default(false)
  recurringExpenseId String?
  createdAt          DateTime        @default(now())
}

model RecurringExpense {
  id          String          @id @default(cuid())
  clinicId    String
  clinic      Clinic          @relation(fields: [clinicId], references: [id])
  description String
  amount      Decimal
  category    ExpenseCategory
  frequency   String          @default("MONTHLY")
  nextDueDate DateTime?
  supplierId  String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
}

model Supplier {
  id            String          @id @default(cuid())
  clinicId      String
  clinic        Clinic          @relation(fields: [clinicId], references: [id])
  name          String
  address       String?
  tin           String?
  vatRegistered Boolean         @default(false)
  category      ExpenseCategory
  createdAt     DateTime        @default(now())

  expenses Expense[]
}

model Employee {
  id               String   @id @default(cuid())
  clinicId         String
  clinic           Clinic   @relation(fields: [clinicId], references: [id])
  fullName         String
  position         String
  dateHired        DateTime
  dailyRate        Decimal                // daily rate (no work no pay)
  sssNumber        String
  philhealthNumber String
  pagibigNumber    String
  tin              String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  payrollRecords         PayrollRecord[]
  salaryHistory          SalaryHistory[]
  attendanceRecords      AttendanceRecord[]
  coverageRecords        AttendanceRecord[]     @relation("CoveredBy")
  thirteenthMonthRecords ThirteenthMonthRecord[]
}

model SalaryHistory {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  dailyRate     Decimal
  effectiveDate DateTime
  notes         String?
  createdAt     DateTime @default(now())
}

// Tracks each employee's attendance per calendar date
model AttendanceRecord {
  id          String    @id @default(cuid())
  clinicId    String
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        DateTime  @db.Date
  status      String    // PRESENT | ABSENT | SICK_LEAVE | VACATION_LEAVE
  coveredById String?
  coveredBy   Employee? @relation("CoveredBy", fields: [coveredById], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([employeeId, date])
}

model PayrollRecord {
  id                   String   @id @default(cuid())
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id])
  clinicId             String
  periodMonth          Int
  periodYear           Int
  periodWeek           Int      @default(1)   // 1–4 (week of the month)
  daysWorked           Int      @default(6)   // days present + coverage days
  basicSalary          Decimal                // daysWorked × dailyRate
  regularHolidayDays   Int      @default(0)   // regular holidays in this week
  specialHolidayDays   Int      @default(0)   // special holidays employee worked
  holidayPay           Decimal  @default(0)   // extra holiday premiums
  sssEmployee          Decimal
  sssEmployer          Decimal
  sssEc                Decimal  @default(0)   // Employees' Compensation (employer-only)
  philhealthEmployee   Decimal
  philhealthEmployer   Decimal
  pagibigEmployee      Decimal
  pagibigEmployer      Decimal
  withholdingTax       Decimal
  netPay               Decimal
  createdAt            DateTime @default(now())
}

// 13th Month Pay tracking (PD 851)
model ThirteenthMonthRecord {
  id             String   @id @default(cuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  year           Int
  totalBasicPay  Decimal  // sum of PayrollRecord.basicSalary for the year
  amount         Decimal  // totalBasicPay ÷ 12
  midYearPaid    Boolean  @default(false)  // June release (optional)
  fullYearPaid   Boolean  @default(false)  // December deadline
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([employeeId, year])
}

model Equipment {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  purchaseDate    DateTime
  purchaseCost    Decimal
  usefulLifeYears Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model ServiceCatalog {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  category  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduledReminder {
  id             String    @id @default(cuid())
  clinicId       String
  clinic         Clinic    @relation(fields: [clinicId], references: [id])
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id])
  visitId        String?
  appointmentId  String?
  reminderType   String    // APPOINTMENT | CLEANING_RECALL | BRACES_ALIGNMENT | SERVICE_RECALL
  scheduledFor   DateTime
  customMessage  String?
  status         String    @default("PENDING")  // PENDING | SENT | FAILED
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
}


model QuarterlyReportLog {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  quarter      Int
  year         Int
  sentAt       DateTime @default(now())
  sentTo       String
  status       String   // SENT | FAILED
  errorMessage String?
}

model LoyaltyCardTemplate {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  serviceName   String
  isFree        Boolean  @default(false)
  tier1Uses     Int      @default(0)
  tier1Discount Decimal  @default(0)
  tier2Uses     Int?
  tier2Discount Decimal?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
}

// RA 10173 — user access audit log: who accessed or changed patient SPI and when
model AuditLog {
  id           String   @id @default(cuid())
  clinicId     String
  userEmail    String
  action       String   // CREATE_PATIENT | VIEW_PATIENT | EDIT_PATIENT_MEDICAL | EDIT_PATIENT_SCPWD | CREATE_VISIT | CONFIRM_PAYMENT | VOID_INVOICE
  resourceType String   // PATIENT | VISIT | INVOICE
  resourceId   String
  detail       String?  // human-readable summary for the audit report
  createdAt    DateTime @default(now())

  @@index([clinicId, createdAt])
  @@index([resourceId])
}

model RecallRule {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  serviceName     String
  serviceCategory String
  daysAfter       Int
  messageTemplate String   @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// One pending intake link per clinic — cleared the moment a patient replies
model PendingMessengerLink {
  id        String   @id @default(cuid())
  clinicId  String   @unique  // only one pending link per clinic at a time
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  patientId String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Tracks a clinic's in-progress upgrade request — generated when they visit the billing page,
// matched by reference code or sender phone when GCash payment is received.
model PendingUpgrade {
  id            String        @id @default(cuid())
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id])
  plan          Plan          // the plan being purchased (BASIC or PRO)
  referenceCode String        @unique  // e.g. SIG-BSC-AB3X — shown to clinic, parsed from GCash note
  amountCents   Int           // 49900 or 99900 (centavos)
  status        UpgradeStatus @default(PENDING)
  gcashTxRef    String?       // GCash's own transaction reference (from notification email)
  senderName    String?       // GCash-registered name of the sender (from notification email)
  createdAt     DateTime      @default(now())
  expiresAt     DateTime      // 7 days from creation; cron expires stale ones
  confirmedAt   DateTime?
  confirmedBy   String?       // 'auto' (Gmail agent) or admin email (manual confirm)

  @@index([clinicId, status])
  @@index([referenceCode])
}

// Immutable audit trail for every SC/PWD discount applied (RA 9994 / RA 10754 compliance)
model ScPwdAuditLog {
  id             String   @id @default(cuid())
  clinicId       String
  patientId      String
  invoiceId      String
  discountType   String   // 'SC' | 'PWD'
  idNumber       String   // ID number presented at time of transaction
  discountPct    Decimal  @default(20)
  discountAmount Decimal
  createdAt      DateTime @default(now())
}
