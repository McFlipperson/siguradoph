DATABASE_URL=
DIRECT_URL=
# Restricted, NOBYPASSRLS Postgres role used by withClinicDb() so RLS actually
# enforces tenant isolation. See docs/RLS_ACTIVATION_RUNBOOK.md.
# Until this is set, the app falls back to DATABASE_URL (RLS stays inert) — no breakage.
TENANT_DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Required for Vercel Cron (patient reminders). Without it /api/reminders/cron 401s
# and reminders never send.
CRON_SECRET=
# Comma-separated emails allowed into /admin (set a clinic's plan when paid).
ADMIN_EMAILS=
